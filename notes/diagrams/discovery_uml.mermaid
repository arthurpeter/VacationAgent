%%{init: { 'theme': 'default', 'themeVariables': { 'background': '#f8fafc', 'primaryColor': '#e0f2fe', 'lineColor': '#475569', 'fontSize': '16px', 'subgraphFontSize': '18px' }}}%%
flowchart LR
    subgraph FRONTEND ["Presentation Layer (Web Client)"]
        direction TB
        A1[New User Input]
        A2[Initialize Stream Connection]
        A3[Process Stream Buffer]
        A4[Live UI Rendering]
        A5[Render Final Output]
    end

    subgraph BACKEND ["Business Logic Layer (Application Server & Agent Engine)"]
        direction TB
        B1[Validate Authentication]
        B2[Resolve Conversation Thread]
        B3[Stream Response Handler]
        B4[Execute Agent Orchestration]
        B5[SSE: Processing Chunk]
        B6[SSE: Stream Complete]
    end

    subgraph PERSISTENCE ["Persistence Layer (Relational Database)"]
        direction TB
        C1[Load Initial Context]
        C2[Resume Previous State]
        C3[Update Session Data]
        C4[Persist Execution Checkpoint]
    end

    A1 --> A2
    A2 -->|HTTP POST| B1
    B1 --> B2
    
    B2 -->|New Session| C1
    B2 -->|Existing Session| C2
    
    C1 --> B4
    C2 --> B4
    
    B3 -->|Open SSE Pipe| A3
    B4 -->|Yield Event| B3
    
    B4 --> C3
    B4 --> C4
    B3 --> B5
    
    B5 -->|Live Chunk| A3
    A3 --> A4
    A4 -->|Read Next Chunk| A3
    
    B3 --> B6
    B6 -->|Final Event| A3
    A3 -->|Close Stream| A5