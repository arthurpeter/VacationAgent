%%{init: { 'theme': 'default', 'themeVariables': { 'background': '#f8fafc', 'primaryColor': '#e0f2fe', 'lineColor': '#475569', 'fontSize': '16px', 'subgraphFontSize': '18px' }}}%%
flowchart LR
    subgraph FRONTEND ["Client (React UI)"]
        direction TB
        A1[Mesaj nou]
        A2[UI: Reading...]
        A3[Citire Buffer]
        A4[Update UI Live]
        A5[Afisare Text AI]
    end

    subgraph BACKEND ["Executie (FastAPI + LangGraph)"]
        direction TB
        B1[Validare Auth]
        B2[Ruta Thread]
        B3[StreamingResponse]
        B4[graph.astream]
        B5[SSE: processing]
        B6[SSE: complete]
    end

    subgraph PERSISTENCE ["Date (PostgreSQL)"]
        direction TB
        C1[Citire Context]
        C2[Sync Sesiune]
        C3[Update Session DB]
        C4[Save Checkpoint]
    end

    A1 --> A2
    A2 -->|POST| B1
    B1 --> B2
    
    B2 -->|Nou| C1
    B2 -->|Existent| C2
    
    C1 --> B4
    C2 --> B4
    
    B3 -->|Deschide Pipe| A3
    B4 -->|Event| B3
    
    B4 --> C3
    B4 --> C4
    B3 --> B5
    
    B5 -->|Live chunk| A3
    A3 --> A4
    A4 -->|Citeste urmatorul| A3
    
    B3 --> B6
    B6 -->|Final chunk| A3
    A3 -->|Final chunk| A5